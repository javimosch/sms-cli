# Default provider (twilio|vonage|mailersend|clickatell)
# If unset, sms-cli auto-detects the first fully-configured provider
SMS_PROVIDER=

# Twilio
TWILIO_ACCOUNT_SID=           # required
TWILIO_AUTH_TOKEN=            # required
TWILIO_FROM=                  # required: E.164 number e.g. +18001234567

# Vonage
VONAGE_API_KEY=               # required
VONAGE_API_SECRET=            # required
VONAGE_FROM=                  # required: sender name or number e.g. MyBrand

# MailerSend
MAILERSEND_API_KEY=           # required
MAILERSEND_FROM=              # required: E.164 number

# Clickatell
CLICKATELL_API_KEY=           # required
CLICKATELL_FROM=              # optional: sender ID
